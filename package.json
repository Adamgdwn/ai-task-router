{
  "name": "ai-task-router",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build --no-bundle",
    "desktop:package:windows:internal": "tauri build --bundles nsis --no-sign --ci --config src-tauri/tauri.internal-windows.conf.json",
    "desktop:package:windows:technical-preview": "tauri build --bundles nsis --no-sign --ci --config src-tauri/tauri.technical-preview.conf.json",
    "desktop:package:macos:technical-preview": "tauri build --bundles dmg --ci --config src-tauri/tauri.technical-preview.conf.json",
    "desktop:package:linux:technical-preview": "tauri build --bundles appimage,deb --ci --config src-tauri/tauri.technical-preview.conf.json",
    "desktop:artifacts": "node scripts/inspect-desktop-artifacts.mjs",
    "desktop:checksums": "node scripts/inspect-desktop-artifacts.mjs --write-checksums --require-artifacts",
    "desktop:gate:technical-preview": "node scripts/desktop-release-gate.mjs --mode technical-preview",
    "desktop:gate:public": "node scripts/desktop-release-gate.mjs --mode public",
    "desktop:info": "tauri info",
    "detect:local-models": "node scripts/detect-local-models.mjs",
    "scan:web-rc": "node scripts/web-release-candidate-scan.mjs",
    "test": "vitest run",
    "test:scripts": "node --test scripts/*.node-test.mjs",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "dexie": "^4.4.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
